# ==============================================================================
# AWAS A3 — MongoDB Reference Configuration
# FIT3182 Assignment 3 | Students: 34377344 & 34076913
# ==============================================================================
#
# Connection: update IP each session (see .env.template Step 1)
#   MONGO_URI = "mongodb://<zealous_shirley_IP>:27017/"
#   Database  = "awas_db"
#
# Variable name differs by notebook (both hold "awas_db"):
#   data_design_streaming + visualisation: MONGO_DB = 'awas_db'
#   ml_training + ml_streaming:            DB_NAME  = 'awas_db'
#
# ==============================================================================
# COLLECTIONS — WHO WRITES WHAT
# ==============================================================================
#
# Collection        │ Created/written by              │ Read by
# ──────────────────┼─────────────────────────────────┼──────────────────────────
# cameras           │ data_design_streaming Cell 5     │ ml_streaming Cell 3
#                   │ (drops + recreates on each run)  │ (loads CAMERA_LIMITS)
# violations        │ data_design_streaming Cell 10/11 │ ml_training, ml_streaming,
#                   │ (A2 violation records)           │ visualisation
# violations (ML)   │ A3_ml_streaming                 │ visualisation
#                   │ (enriches existing docs with     │
#                   │  risk_score, risk_label etc.)    │
# watchlist         │ A3_ml_streaming                 │ visualisation
# proactive_alerts  │ A3_ml_streaming                 │ visualisation
#
# NOTE: The 'cameras' collection IS written by data_design_streaming and IS
# read by A3_ml_streaming. It must exist before ml_streaming Cell 3 runs.
# Run data_design_streaming at least through Cell 5 before starting ml_streaming.
#
# ==============================================================================
# COLLECTION SCHEMAS
# ==============================================================================
#
# cameras (written by data_design_streaming Cell 5):
#   {
#     camera_id:  int (1, 2, or 3),
#     speed_limit: float (110.0 or 90.0),
#     location:   GeoJSON Point { type: "Point", coordinates: [lon, lat] },
#     latitude:   float,
#     longitude:  float
#   }
#   Indexes: camera_id (unique), location (2dsphere)
#
# violations (written by data_design_streaming, enriched by ml_streaming):
#   {
#     car_plate:    string,
#     date:         string (YYYY-MM-DD),
#     violations: [
#       {
#         violation_type:  "INSTANTANEOUS" | "AVERAGE",
#         camera_id_start: int,
#         camera_id_end:   int,        (AVERAGE only)
#         timestamp_start: string,
#         timestamp_end:   string,     (AVERAGE only)
#         speed_reading:   float
#       }
#     ],
#     # Fields added by A3_ml_streaming after scoring:
#     risk_score:   float   (0.0 or 1.0 in current implementation),
#     risk_label:   "HIGH_RISK" | "LOW_RISK",
#     predicted_at: string (ISO datetime),
#     ml_batch_id:  string
#   }
#
# watchlist (written by A3_ml_streaming):
#   {
#     car_plate:      string,
#     risk_score:     float,
#     flagged_at:     string (ISO datetime),
#     expires_at:     string (ISO datetime = flagged_at + 24 hours),
#     last_seen_date: string (YYYY-MM-DD)
#   }
#
# proactive_alerts (written by A3_ml_streaming):
#   {
#     car_plate:        string,
#     camera_id:        int,
#     speed_reading:    float,
#     speed_over_limit: float,
#     timestamp:        string (ISO datetime),
#     flag_type:        "WATCHLIST_HIT"
#   }
#
# ==============================================================================
# INSPECTION COMMANDS (docker exec -it zealous_shirley mongosh awas_db)
# ==============================================================================
#
# Count all collections:
#   db.cameras.countDocuments()
#   db.violations.countDocuments()
#   db.watchlist.countDocuments()
#   db.proactive_alerts.countDocuments()
#
# Check cameras loaded correctly (must run before ml_streaming):
#   db.cameras.find().limit(3)
#
# Check a violation before ML scoring:
#   db.violations.findOne({ risk_score: { $exists: false } })
#
# Check a violation after ML scoring:
#   db.violations.findOne({ risk_score: { $exists: true } })
#
# Count HIGH_RISK vs LOW_RISK:
#   db.violations.countDocuments({ risk_label: "HIGH_RISK" })
#   db.violations.countDocuments({ risk_label: "LOW_RISK"  })
#
# Active watchlist entries (not expired):
#   var now = new Date().toISOString()
#   db.watchlist.find({ expires_at: { $gt: now } }).limit(5)
#
# ==============================================================================
# RESET A3 STATE BETWEEN RUNS (keeps A2 violations and cameras intact)
# ==============================================================================
#
# In mongosh (docker exec -it zealous_shirley mongosh awas_db):
#
#   db.watchlist.drop()
#   db.proactive_alerts.drop()
#   db.violations.updateMany(
#     { risk_score: { $exists: true } },
#     { $unset: { risk_score: "", risk_label: "", predicted_at: "", ml_batch_id: "" } }
#   )
#
# To reset EVERYTHING including A2 data (full clean slate):
#   db.cameras.drop()
#   db.violations.drop()
#   db.watchlist.drop()
#   db.proactive_alerts.drop()
#   (Then re-run data_design_streaming from Cell 5)
#
