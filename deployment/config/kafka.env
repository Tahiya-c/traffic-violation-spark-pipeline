# ==============================================================================
# AWAS A3 — Kafka Reference Configuration
# FIT3182 Assignment 3 | Students: 34377344 & 34076913
# ==============================================================================
#
# The Kafka broker runs inside the kafka_a2 Docker container, which was
# originally configured for A2. Do NOT modify the container's internal
# broker settings — they are baked in at creation time.
#
# ==============================================================================
# TOPICS REQUIRED
# ==============================================================================
#
# Topic             │ Partitions │ Replication │ Consumed by
# ──────────────────┼────────────┼─────────────┼────────────────────────────────
# camera-events-A   │     1      │      1      │ data_design_streaming (A2 joins)
#                   │            │             │ A3_ml_streaming (ML inference)
# camera-events-B   │     1      │      1      │ data_design_streaming + ml_streaming
# camera-events-C   │     1      │      1      │ data_design_streaming + ml_streaming
#
# ==============================================================================
# VERIFY TOPICS EXIST (run before starting producers)
# ==============================================================================
#
#   docker exec kafka_a2 kafka-topics --bootstrap-server localhost:9092 --list
#
# ==============================================================================
# CREATE TOPICS IF MISSING
# ==============================================================================
#
# Windows PowerShell (run each line separately):
#   docker exec kafka_a2 kafka-topics --bootstrap-server localhost:9092 `
#     --create --if-not-exists --topic camera-events-A `
#     --partitions 1 --replication-factor 1
#
#   docker exec kafka_a2 kafka-topics --bootstrap-server localhost:9092 `
#     --create --if-not-exists --topic camera-events-B `
#     --partitions 1 --replication-factor 1
#
#   docker exec kafka_a2 kafka-topics --bootstrap-server localhost:9092 `
#     --create --if-not-exists --topic camera-events-C `
#     --partitions 1 --replication-factor 1
#
# Mac/Linux (use setup_kafka_topics.sh script instead):
#   ./deployment/scripts/setup_kafka_topics.sh
#
# ==============================================================================
# CONNECTION VARIABLE NAMES BY NOTEBOOK
# ==============================================================================
#
# IMPORTANT: The Kafka connection variable is named differently in each notebook.
# Both hold the value <kafka_a2_IP>:9092 — only the Python variable name differs.
#
#   data_design_streaming.ipynb Cell 3:  KAFKA_BROKER   = "<kafka_a2_IP>:9092"
#   A3_ml_streaming.ipynb        Cell 2:  KAFKA_BOOTSTRAP = "<kafka_a2_IP>:9092"
#   producer_a/b/c.ipynb         Cell 3:  HOST_IP = "<machine LAN IPv4>"
#                                         (producers derive bootstrap from HOST_IP)
#
# ==============================================================================
# WHY PRODUCERS USE A DIFFERENT IP THAN STREAMING NOTEBOOKS
# ==============================================================================
#
# producer_a/b/c.ipynb use HOST_IP = machine LAN IPv4.
# This is because the KafkaProducer inside spark_a2 connects to Kafka via
# the host machine's advertised listener (external access path).
#
# A3_ml_streaming.ipynb and data_design_streaming.ipynb use the kafka_a2
# Docker bridge IP directly, because Spark's Kafka connector accesses the
# broker via the internal Docker network.
#
# Using the wrong IP for either will cause a connection refused error.
#
# ==============================================================================
# CHECKPOINT PATHS
# ==============================================================================
#
# data_design_streaming.ipynb:
#   Cell 3 defines:  CHECKPOINT_BASE = '/home/student/checkpoints'
#   Cell 12 overrides to: '/tmp/checkpoints'  <-- this is what runs
#   Three subdirs used: /tmp/checkpoints/instant, /tmp/checkpoints/avg_ab,
#                       /tmp/checkpoints/avg_bc
#
# A3_ml_streaming.ipynb:
#   Uses: '/tmp/awas_ml_checkpoint'
#
# These are separate directories and must NOT be shared between notebooks.
# If a streaming query fails to start, delete the checkpoint dir and retry:
#   docker exec spark_a2 rm -rf /tmp/checkpoints /tmp/awas_ml_checkpoint
#
# ==============================================================================
# CHECK CONSUMER GROUP LAG (monitor ml_streaming progress)
# ==============================================================================
#
#   docker exec kafka_a2 kafka-consumer-groups `
#     --bootstrap-server localhost:9092 `
#     --describe --group spark-awas-ml
#
# LAG=0 means the ML streaming query has consumed all available messages.
# Growing LAG means the query cannot keep up — reduce producer send rate.
#
# ==============================================================================
# PURGE TOPICS BETWEEN RUNS (reset offsets)
# ==============================================================================
#
#   docker exec kafka_a2 kafka-topics --bootstrap-server localhost:9092 `
#     --delete --topic camera-events-A
#   docker exec kafka_a2 kafka-topics --bootstrap-server localhost:9092 `
#     --create --topic camera-events-A --partitions 1 --replication-factor 1
#
# Repeat for B and C. Also delete checkpoint dirs after purging topics.
#
