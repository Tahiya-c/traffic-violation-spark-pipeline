# ==============================================================================
# STEP 1 — Get container IPs (run in PowerShell at session start)
# ==============================================================================
#
#   docker inspect zealous_shirley --format "{{.NetworkSettings.IPAddress}}"
#   docker inspect kafka_a2        --format "{{.NetworkSettings.IPAddress}}"
#
#   zealous_shirley (MongoDB) IP: _______________   e.g. 172.17.0.3
#   kafka_a2        (Kafka)   IP: _______________   e.g. 172.17.0.4
#
# ==============================================================================
# STEP 2 — Get your machine LAN IPv4 (for producer notebooks only)
# ==============================================================================
#
#   Windows:   ipconfig | Select-String "IPv4"
#   Mac/Linux: ifconfig | grep "inet " | grep -v 127
#
#   Your machine LAN IPv4: _______________   e.g. 192.168.68.55
#
# ==============================================================================
# STEP 3 — What to update in each notebook
# ==============================================================================
#
# ┌──────────────────────────────────────┬────────────────────┬──────────────────────────────────────────┐
# │ Notebook                             │ Config location    │ Variables to update                      │
# ├──────────────────────────────────────┼────────────────────┼──────────────────────────────────────────┤
# │ A3_ml_training.ipynb                 │ Cell 3             │ MONGO_URI                                │
# │ A3_ml_streaming.ipynb                │ Cell 3             │ MONGO_URI, KAFKA_BOOTSTRAP               │
# │ data_design_streaming.ipynb          │ Section 0 (code)   │ KAFKA_BROKER, MONGO_URI                  │
# │ A3_visualisation.ipynb               │ Cell 3             │ HOST_IP  ← set to MongoDB IP             │
# │ producer_a/b/c.ipynb                 │ Cell 3             │ HOST_IP  ← set to machine LAN IPv4       │
# └──────────────────────────────────────┴────────────────────┴──────────────────────────────────────────┘
#
# Exact values to paste per notebook:
#
#   A3_ml_training.ipynb — Cell 3:
#     MONGO_URI = "mongodb://<zealous_shirley_IP>:27017/"
#
#   A3_ml_streaming.ipynb — Cell 3:
#     MONGO_URI       = "mongodb://<zealous_shirley_IP>:27017/"
#     KAFKA_BOOTSTRAP = "<kafka_a2_IP>:9092"
